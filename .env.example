# Mantle RPC (swap for your own node)
MANTLE_RPC=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz

# Deployer / committer wallet (TESTNET ONLY — never fund on mainnet)
DEPLOYER_PK=0xyour_testnet_private_key

# Telegram
TELEGRAM_TOKEN=your_botfather_token

# LLM (OpenAI-compatible gateway)
DEEPSEEK_API_KEY=your_llm_key
LLM_BASE_URL=https://your-gateway/v1
LLM_MODEL=deepseek-v4-flash

# Database
DATABASE_URL=postgres://veritas:veritas@localhost:5432/veritas

# Contract addresses (filled after deploy)
SMART_MONEY_INDEX_ADDR=
ERC8004_IDENTITY_ADDR=
